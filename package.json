{
  "name": "rickandmorty",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "dev:vite": "vite --host",
    "dev:watch-types": "tsc --noEmit --watch",
    "serve": "vite preview",
    "type-check": "tsc",
    "test": "vitest",
    "check-types": "tsc --noEmit",
    "codegen": "graphql-codegen --config codegen.yml src/generated/graphql.tsx",
    "eslint": "eslint src",
    "eslint-fix": "eslint src --fix",
    "stylelint": "npx stylelint \"src/**/*.scss\" --color",
    "stylelint-fix": "npx stylelint \"src/**/*.scss\" --color --fix",
    "prettify": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json}\""
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "classnames": "^2.5.1",
    "graphql": "^16.8.1",
    "jotai": "^2.6.4",
    "lodash": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^6.1.2",
    "@graphql-codegen/schema-ast": "^5.0.0",
    "@graphql-codegen/typed-document-node": "^6.1.6",
    "@graphql-codegen/typescript": "^5.0.8",
    "@graphql-codegen/typescript-graphql-files-modules": "^3.0.0",
    "@graphql-codegen/typescript-operations": "^5.0.8",
    "@testing-library/react": "^14.0.0",
    "@types/lodash": "^4.14.202",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^1.2.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jsdom": "^19.0.0",
    "prettier": "^3",
    "sass": "^1.70.0",
    "stylelint": "^16.2.1",
    "stylelint-config-css-modules": "^4.4.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "stylelint-order": "^6.0.4",
    "typescript": "^5.7",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.0.11",
    "vite-plugin-svgr": "^4.2.0",
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "^0.7.11"
  },
  "license": "MIT",
  "lint-staged": {
    "src/**/*.scss": [
      "yarn run stylelint"
    ],
    "src/**/*.{js,jsx,ts,tsx}": [
      "yarn run prettify",
      "yarn run eslint"
    ]
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
